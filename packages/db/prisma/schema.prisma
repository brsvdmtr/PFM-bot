generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────

enum Currency {
  RUB
  USD
  EUR
  GBP
  CHF
  CNY
  JPY
  AED
  TRY
  USDT
}

enum DebtType {
  CREDIT
  MORTGAGE
  CREDIT_CARD
  CAR_LOAN
  PERSONAL_LOAN
  OTHER
}

enum IncomeFrequency {
  MONTHLY
  BIWEEKLY
  WEEKLY
  IRREGULAR
}

enum ObligationType {
  RENT
  UTILITIES
  SUBSCRIPTION
  TELECOM
  INSURANCE
  ENVELOPE
  OTHER
}

enum PeriodStatus {
  ACTIVE
  COMPLETED
  DEFICIT
}

enum ExpenseSource {
  MANUAL
  IMPORT
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum DebtPaymentKind {
  REQUIRED_MIN_PAYMENT
  EXTRA_PRINCIPAL_PAYMENT
}

enum DebtPaymentSource {
  MANUAL
  SYSTEM
}

// ── Core Models ────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  telegramId      String?   @unique
  telegramChatId  String?
  firstName       String?
  godMode         Boolean   @default(false)
  onboardingDone  Boolean   @default(false)
  timezone        String    @default("Europe/Moscow")
  locale          String    @default("ru")
  localeUserSet   Boolean   @default(false)
  primaryCurrency Currency  @default(RUB)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile            UserProfile?
  settings           UserSettings?
  incomes            Income[]
  obligations        Obligation[]
  debts              Debt[]
  periods            Period[]
  expenses           Expense[]
  emergencyFund      EmergencyFund?
  subscription       Subscription?
  paymentEvents      PaymentEvent[]
  debtPaymentEvents  DebtPaymentEvent[]
  efEntries          EmergencyFundEntry[]
  efPlan             EmergencyFundPlan?
  savingsBuckets     SavingsBucket[]
  freeCashEvents     FreeCashEvent[]
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  morningNotifyTime    String   @default("09:00")
  eveningNotifyTime    String   @default("21:00")
  morningNotifyEnabled Boolean  @default(true)
  eveningNotifyEnabled Boolean  @default(true)
  paymentAlerts        Boolean  @default(true)
  deficitAlerts        Boolean  @default(true)
  weeklyDigest         Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Income & Obligations ───────────────────────────────

model Income {
  id        String          @id @default(cuid())
  userId    String
  title     String
  amount    Int
  currency  Currency        @default(RUB)
  frequency IncomeFrequency @default(MONTHLY)
  paydays   Int[]
  isActive               Boolean         @default(true)
  useRussianWorkCalendar Boolean         @default(false)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Obligation {
  id        String         @id @default(cuid())
  userId    String
  title     String
  type      ObligationType
  amount    Int
  currency  Currency       @default(RUB)
  dueDay    Int?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Debts ──────────────────────────────────────────────

model Debt {
  id             String    @id @default(cuid())
  userId         String
  title          String
  type           DebtType
  balance        Int
  originalAmount Int?
  apr            Float
  minPayment     Int
  currency       Currency  @default(RUB)
  dueDay         Int?
  isFocusDebt    Boolean   @default(false)
  isPaidOff      Boolean   @default(false)
  paidOffAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments      DebtPayment[]
  paymentEvents DebtPaymentEvent[]
}

model DebtPayment {
  id      String   @id @default(cuid())
  debtId  String
  amount  Int
  isExtra Boolean  @default(false)
  paidAt  DateTime @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)
}

// ── Periods & Expenses ─────────────────────────────────

model Period {
  id                String       @id @default(cuid())
  userId            String
  startDate         DateTime
  endDate           DateTime
  totalIncome       Int
  totalObligations  Int
  totalDebtPayments Int
  efContribution    Int
  reserve           Int
  s2sPeriod         Int
  s2sDaily          Int
  status            PeriodStatus @default(ACTIVE)
  daysTotal         Int
  currency          Currency     @default(RUB)
  isProratedStart   Boolean      @default(false)
  triggerPayday     Int?
  cashAnchorAmount  Int?
  cashAnchorAt      DateTime?
  lastIncomeDate    DateTime?
  nextIncomeDate    DateTime?
  nextIncomeAmount  Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses          Expense[]
  dailySnapshots    DailySnapshot[]
  debtPaymentEvents DebtPaymentEvent[]
  efEntries         EmergencyFundEntry[]

  @@index([userId, status])
}

model Expense {
  id        String        @id @default(cuid())
  userId    String
  periodId  String
  amount    Int
  currency  Currency      @default(RUB)
  note      String?
  source    ExpenseSource @default(MANUAL)
  spentAt   DateTime      @default(now())
  createdAt DateTime      @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  period Period @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId, spentAt])
}

model DailySnapshot {
  id            String   @id @default(cuid())
  periodId      String
  date          DateTime
  s2sPlanned    Int
  s2sActual     Int
  totalExpenses Int
  isOverspent   Boolean  @default(false)
  createdAt     DateTime @default(now())

  period Period @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([periodId, date])
}

// ── Debt Payment Events ────────────────────────────────

model DebtPaymentEvent {
  id          String            @id @default(cuid())
  userId      String
  debtId      String
  periodId    String
  amountMinor Int
  paymentDate DateTime          @default(now())
  kind        DebtPaymentKind
  source      DebtPaymentSource @default(MANUAL)
  note        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt   Debt   @relation(fields: [debtId], references: [id], onDelete: Cascade)
  period Period @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([userId, periodId])
  @@index([debtId, periodId])
}

// ── Emergency Fund & Savings ────────────────────────────

model EmergencyFund {
  id            String               @id @default(cuid())
  userId        String               @unique
  currentAmount Int                  @default(0) // derived: sum of included buckets (legacy compat)
  targetMonths  Int                  @default(3)
  currency      Currency             @default(RUB)
  updatedAt     DateTime             @updatedAt

  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries EmergencyFundEntry[]
  plan    EmergencyFundPlan?
  buckets SavingsBucket[]
}

enum EFTargetMode {
  BY_SALARY
  BY_EXPENSES
  MANUAL
}

enum ContributionFrequency {
  MONTHLY
  BIWEEKLY
  WEEKLY
}

enum SavingsPace {
  GENTLE
  OPTIMAL
  AGGRESSIVE
}

model EmergencyFundPlan {
  id                      String                 @id @default(cuid())
  userId                  String                 @unique
  emergencyFundId         String                 @unique

  targetMode              EFTargetMode           @default(BY_SALARY)
  baseMonthlyAmount       Int?                   // manual override for income base (minor units)
  targetMonths            Int?                   @default(3)
  manualTargetAmount      Int?                   // only for MANUAL mode (minor units)

  targetDeadlineAt        DateTime?
  contributionFrequency   ContributionFrequency  @default(MONTHLY)
  preferredPace           SavingsPace?

  planSelectionMode             String?            // 'SYSTEM' | 'CUSTOM'
  customContributionAmount      Int?               // minor units
  customContributionFrequency   String?            // 'MONTHLY' | 'BIWEEKLY' | 'WEEKLY'

  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  emergencyFund EmergencyFund @relation(fields: [emergencyFundId], references: [id], onDelete: Cascade)
}

enum BucketType {
  SAVINGS_ACCOUNT
  DEPOSIT
  CASH
  CRYPTO
  BROKERAGE
  OTHER
}

model SavingsBucket {
  id                         String     @id @default(cuid())
  userId                     String
  emergencyFundId            String
  name                       String
  type                       BucketType
  currency                   Currency   @default(RUB)
  currentAmount              Int        @default(0) // minor units
  countsTowardEmergencyFund  Boolean    @default(true)
  isArchived                 Boolean    @default(false)
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  emergencyFund EmergencyFund      @relation(fields: [emergencyFundId], references: [id], onDelete: Cascade)
  entries       EmergencyFundEntry[]

  @@index([userId])
  @@index([emergencyFundId])
}

enum EFEntryType {
  DEPOSIT
  WITHDRAWAL
  BALANCE_SYNC
  CORRECTION
}

model EmergencyFundEntry {
  id                   String      @id @default(cuid())
  userId               String
  emergencyFundId      String
  bucketId             String?
  periodId             String?
  type                 EFEntryType
  amount               Int         // minor units, always positive
  affectsCurrentBudget Boolean     @default(false)
  note                 String?
  createdAt            DateTime    @default(now())
  reversedAt           DateTime?

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  emergencyFund EmergencyFund   @relation(fields: [emergencyFundId], references: [id], onDelete: Cascade)
  bucket        SavingsBucket?  @relation(fields: [bucketId], references: [id], onDelete: SetNull)
  period        Period?         @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([emergencyFundId])
  @@index([bucketId])
  @@index([periodId])
}

// ── Billing ────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  planCode           String             @default("PRO")
  status             SubscriptionStatus @default(ACTIVE)
  starsPrice         Int
  telegramChargeId   String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentEvent {
  id                      String   @id @default(cuid())
  userId                  String
  subscriptionId          String?
  telegramPaymentChargeId String   @unique
  totalAmount             Int
  currency                String   @default("XTR")
  eventType               String
  createdAt               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Free Cash Recommendation history ──────────────────────
//
// Every time a user applies a "free cash" windfall (bonus, premium, gift)
// we record the system's recommendation and the user's actual choice, so we
// can later tune thresholds (protectiveThresholdMonths, highAprThreshold)
// from real data. See apps/api/src/domain/finance/freeCashRecommendation.ts.

enum FreeCashMode {
  EMERGENCY_FUND
  DEBT_PREPAY
  SPLIT
}

enum FreeCashReason {
  NO_SIGNIFICANT_AMOUNT
  NO_DEBT
  EF_PROTECTIVE
  EF_FULLY_FUNDED
  HIGH_APR_DEBT
  BALANCED_SPLIT
}

model FreeCashEvent {
  id               String          @id @default(cuid())
  userId           String
  periodId         String?         // active period when the event was created (nullable: may be missing)
  amountMinor      Int             // total windfall (kopecks)
  currency         Currency        @default(RUB)

  // Recommendation snapshot (what the engine said at the time)
  recommendedMode  FreeCashMode
  reasonCode       FreeCashReason

  // Actual user choice (may differ from recommendation)
  chosenMode       FreeCashMode
  splitEfShare     Float           @default(0.5) // 0..1, only meaningful for SPLIT
  toEfMinor        Int             // kopecks applied to EF
  toDebtMinor      Int             // kopecks applied to debt
  focusDebtId      String?         // the debt that received the prepay (null if EF-only)

  // Snapshot of inputs for later analysis (not foreign keys, just values)
  efCurrentMinor   Int             // EF balance at decision time
  efTargetMinor    Int             // EF target at decision time
  monthlyEssentialsMinor Int       // monthly obligations at decision time

  note             String?
  createdAt        DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([periodId])
}
