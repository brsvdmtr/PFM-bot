# Database
DATABASE_URL="postgresql://pfm:pfm_secret@localhost:5432/pfm?schema=public"
POSTGRES_USER=pfm
POSTGRES_PASSWORD=pfm_secret
POSTGRES_DB=pfm

# Telegram Bot
BOT_TOKEN=your_bot_token_here
