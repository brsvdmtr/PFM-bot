{
  "name": "pfm-bot",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @pfm/api dev",
    "dev:bot": "pnpm --filter @pfm/bot dev",
    "dev:web": "pnpm --filter @pfm/web dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @pfm/db generate",
    "db:migrate": "pnpm --filter @pfm/db migrate",
    "db:push": "pnpm --filter @pfm/db push",
    "db:studio": "pnpm --filter @pfm/db studio",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ],
    "ignoredBuiltDependencies": []
  }
}